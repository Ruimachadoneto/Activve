# Copie as opções desejadas para .codex/config.toml ou ~/.codex/config.toml.
# Revise compatibilidade com a versão instalada do Codex.

model = "gpt-5.5"
review_model = "gpt-5.5"
approval_policy = "on-request"
sandbox_mode = "workspace-write"
web_search = "cached"

[sandbox_workspace_write]
network_access = false

# Exemplo opcional de configuração do MCP.
# Prefira habilitar somente integrações realmente necessárias.
#
# [mcp_servers.exemplo]
# command = "npx"
# args = ["-y", "pacote-do-servidor-mcp"]
